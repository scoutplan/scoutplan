<%= render Email::Heading.new(
  text: "Coming up this week",
  size: "30px",
  align: "center",
  margin: "20px auto 30px auto"
) %>
<%= render Email::Divider.new(color: Email::Colors::BRAND_500, thickness: "4px", margin: "1rem 0") %>

<table style="width: 100%;" cellpadding=0 cellspacing=0>
  <% @this_week_events.each_with_index do |event, index| %>
    <% style = index > 0 ? "border-top: 1px solid #ccc; padding: 8px 0;" : "padding: 8px 0;" %>
    <tr>
      <td style="<%= style %>">
        <%= link_to unit_event_url(event.unit, event), style: "text-decoration: none;" do %>
          <%= render Email::Heading.new(text: event.title, margin: "0") %>
          <%= render Email::Text.new(text: raw(event.dates_to_s_with_month + " (" + event.days_to_s + ")"), margin: "0") %>
          <%= render Email::Text.new(text: event.location, margin: "0", size: "14px", bold: true, color: Email::Colors::GRAY_500) if event.location.present? %>
        <% end %>
      </td>

      <td style="<%= style %>" align="right">
        <%= render partial: "needs_attention", locals: { event: event, recipient: @recipient } %>
      </td>
    </tr>
  <% end %>
</table>

<%= render Email::Divider.new(color: Email::Colors::BRAND_500, thickness: "1px", margin: "1rem 0") %>
<%= render Email::Text.new(text: "The links in this email are personalized for you. Please don't share or forward to others.", size: "14px") %>
